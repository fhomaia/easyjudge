DATABASE_URL=postgres://easyjudge:easyjudge@localhost:5432/easyjudge
JWT_SECRET=
PORT=3000

# Opcional — sem ela, o MailService só loga o código no console (modo
# stub, útil pra dev local). Gerar em resend.com/api-keys.
RESEND_API_KEY=
# Opcional — remetente. Sem domínio verificado no Resend, precisa ser
# o sandbox onboarding@resend.dev (só entrega pro email da conta Resend).
EMAIL_FROM=easyJudge <onboarding@resend.dev>
# Opcional — enquanto o domínio não é verificado no Resend, redireciona
# TODOS os emails pra esse endereço (o corpo mostra o cadastro real).
# Remover quando não precisar mais forçar entrega num único destinatário.
EMAIL_OVERRIDE_TO=
